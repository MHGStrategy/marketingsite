# Copy to .env.local for local development.
# See lib/forms/README.md and APPS_SCRIPT_LEADS_ENDPOINT.md for form configuration.

# Leads endpoint (Google Apps Script Web App)
NEXT_PUBLIC_LEADS_WEBAPP_URL=

# Intake API (MHGSYNC backend)
NEXT_PUBLIC_MHGSYNC_INTAKE_URL=

# Cal.com — paste your live event type URLs after creating them in Cal.com
# Example: https://cal.com/your-username/webops-discovery
NEXT_PUBLIC_CAL_WEBOPS_URL=
NEXT_PUBLIC_CAL_REVOPS_URL=
NEXT_PUBLIC_CAL_MANAGEDOPS_URL=
